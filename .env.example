# Google Gemini API Key
# Get your API key from Google AI Studio (https://aistudio.google.com/api-keys)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend API Configuration (Defaults to http://127.0.0.1:8000)
BACKEND_API_URL=http://127.0.0.1:8000


#Rename this file to .env and replace the placeholder values with actual API keys.

